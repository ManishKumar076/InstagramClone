# Copy this file to .env and fill values for local development
# Example local MongoDB (Docker/local): mongodb://localhost:27017/instagram_clone
MONGO_URI=
LOCAL_MONGO_URI=mongodb://localhost:27017/instagram_clone
PORT=8000
SECRET_KEY=your_jwt_secret_here

# Cloudinary (optional - required for profile image uploads)
CLOUD_NAME=
API_KEY=
API_SECRET=

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173
